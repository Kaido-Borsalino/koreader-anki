#!/usr/bin/env python3
"""
KoReader → Anki
Beautiful Mac app to convert KoReader annotations to Anki cloze cards.
"""

import re, sys, json, time, sqlite3, os, csv, threading, configparser
from pathlib import Path

try:
    import customtkinter as ctk
    from tkinter import filedialog, messagebox
except ImportError:
    print("Run install.sh first.")
    sys.exit(1)

try:
    import anthropic, requests
except ImportError:
    print("Run install.sh first.")
    sys.exit(1)

# ── Constants ─────────────────────────────────────────────────────────────────
CONFIG_PATH = Path.home() / ".koreader_anki.cfg"
ANKI_URL    = "http://localhost:8765"
MODEL_NAME  = "KoReader Cloze"
BATCH_SIZE  = 5
VERSION     = "1.0.0"

ACCENT   = "#c8f060"
BG_DARK  = "#0e0f11"
BG_MID   = "#16181c"
BG_CARD  = "#1e2026"
MUTED    = "#7a7e88"
DANGER   = "#f87171"
SUCCESS  = "#4ade80"
INFO     = "#5b9cf6"

CARD_CSS = """
.card{font-family:'DM Sans',sans-serif;background:#0e0f11;color:#f0f0ee;
padding:28px 24px;min-height:100vh;display:flex;flex-direction:column;justify-content:center;}
.phase{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:#7a7e88;margin-bottom:18px;}
.cloze-sentence{font-family:'DM Serif Display',serif;font-size:1.5em;line-height:1.7;
color:#f0f0ee;margin-bottom:20px;}
.blank{display:inline-block;border-bottom:2px solid #c8f060;min-width:100px;}
.hint-box{background:#1e2026;border-radius:8px;padding:10px 14px;font-size:.82em;
color:#7a7e88;font-style:italic;margin-bottom:20px;}
.answer-word{font-family:'DM Serif Display',serif;font-size:2.5em;color:#c8f060;
line-height:1.1;margin-bottom:6px;}
.phonetic{font-size:.85em;color:#7a7e88;margin-bottom:14px;}
.type-pill{display:inline-block;background:rgba(91,156,246,.15);color:#5b9cf6;
padding:2px 12px;border-radius:999px;font-size:.72em;font-weight:500;
text-transform:uppercase;letter-spacing:.06em;margin-bottom:16px;}
.cloze-filled{font-family:'DM Serif Display',serif;font-size:1.1em;line-height:1.7;
color:#7a7e88;background:#1e2026;padding:12px 16px;border-left:3px solid #c8f060;
border-radius:6px;margin-bottom:14px;}
.cloze-filled b{color:#c8f060;font-style:italic;}
.definition{font-size:.88em;color:#a0a4ae;line-height:1.6;margin-bottom:10px;}
.french{font-size:.88em;color:#5b9cf6;font-weight:500;}
.book{font-size:.7em;color:#3a3e48;margin-top:16px;}
hr{border:none;border-top:0.5px solid #1e2026;margin:16px 0;}
"""

FRONT = """<div class="card">
  <div class="phase">Phase 1 — Active Recall</div>
  <div class="cloze-sentence">{{ClozeSentence}}</div>
  <div class="hint-box">💡 {{Hint}}</div>
</div>"""

BACK = """<div class="card">
  <div class="answer-word">{{Word}}</div>
  <div class="phonetic">{{Phonetic}}</div>
  <div class="type-pill">{{Type}}</div>
  <div class="cloze-filled">{{ClozeSentence}}</div>
  <hr>
  <div class="definition">{{Definition}}</div>
  <div class="french">🇫🇷 {{French}}</div>
  <div class="book">📖 {{Book}}</div>
</div>"""


# ── Config ────────────────────────────────────────────────────────────────────
def load_config():
    cfg = configparser.ConfigParser()
    if CONFIG_PATH.exists():
        cfg.read(CONFIG_PATH)
    return cfg

def save_config(api_key, deck):
    cfg = configparser.ConfigParser()
    cfg["settings"] = {"api_key": api_key, "deck": deck}
    with open(CONFIG_PATH, "w") as f:
        cfg.write(f)


# ── Parsers ───────────────────────────────────────────────────────────────────
def parse_lua(path):
    with open(path, encoding="utf-8", errors="replace") as f:
        txt = f.read()

    if '["annotations"]' in txt:
        title_m = re.search(r'\["title"\]\s*=\s*"([^"]+)"', txt)
        book = title_m.group(1).strip() if title_m else Path(path).stem
        section = txt[txt.find('["annotations"]'):]
        entries, seen = [], set()
        for m in re.finditer(r'\["text"\]\s*=\s*"((?:[^"\\]|\\.)*)"', section):
            phrase = m.group(1).replace("\\n"," ").replace('\\"','"').replace("\\\\","\\")
            phrase = re.sub(r"\s+", " ", phrase).strip()
            if not phrase or len(phrase) < 2: continue
            if sum(1 for c in phrase if c.isalpha() and ord(c)<256)/max(len(phrase),1) < 0.5: continue
            key = phrase.lower()
            if key in seen: continue
            seen.add(key)
            entries.append({"word": phrase, "book": book, "context": ""})
        if entries: return entries

    entries = []
    for m in re.finditer(r'\["([^"]+)"\]\s*=\s*\{([^}]+)\}', txt):
        word, block = m.group(1).strip(), m.group(2)
        bk  = re.search(r'book_title\s*=\s*"([^"]*)"', block)
        ctx = re.search(r'context\s*=\s*"([^"]*)"', block)
        if bk or ctx:
            entries.append({"word": word, "book": bk.group(1) if bk else "", "context": ctx.group(1) if ctx else ""})
    if entries: return entries

    entries = []
    for m in re.finditer(r'\["([a-zA-Z][a-zA-Z\' -]{1,40})"\]\s*=', txt):
        w = m.group(1).strip()
        if len(w) > 1: entries.append({"word": w, "book": "", "context": ""})
    return entries

def parse_sqlite(path):
    conn = sqlite3.connect(path)
    for q in [
        "SELECT word, book_title, context FROM vocabulary ORDER BY create_time DESC",
        "SELECT word, book_title, context FROM vocabulary",
        "SELECT word, '', '' FROM vocabulary",
    ]:
        try:
            rows = conn.execute(q).fetchall()
            if rows:
                conn.close()
                return [{"word":(r[0]or"").strip(),"book":r[1]or"","context":r[2]or""} for r in rows if r[0]]
        except: pass
    conn.close()
    return []

def parse_csv_file(path):
    entries = []
    with open(path, encoding="utf-8", errors="replace") as f:
        reader = csv.DictReader(f)
        for row in reader:
            word = row.get("word") or row.get("Word") or row.get("term") or list(row.values())[0]
            if word and len(word.strip()) > 1:
                entries.append({"word": word.strip(), "book": row.get("book",""), "context": row.get("context","")})
    return entries

def load_words(path):
    ext = Path(path).suffix.lower()
    if ext == ".lua": return parse_lua(path)
    if ext in (".sqlite", ".db"): return parse_sqlite(path)
    if ext == ".csv": return parse_csv_file(path)
    return []


# ── Claude ────────────────────────────────────────────────────────────────────
def generate_cards(batch, client):
    items = "\n".join(
        f'- text: "{w["word"]}"' + (f'\n  context: "{w["context"][:100]}"' if w["context"] else "")
        for w in batch
    )
    msg = client.messages.create(
        model="claude-opus-4-5",
        max_tokens=1500,
        messages=[{"role":"user","content":f"""You are an expert English vocabulary coach creating Anki cloze flashcards.

For each item (word, phrase, or expression from a novel), generate a flashcard.

Items:
{items}

Rules:
- word: exact text as given
- cloze_sentence: vivid English sentence where the key word/phrase is replaced by ___
- hint: vague definition 10-15 words, helps recall WITHOUT revealing the answer
- phonetic: IPA for single words; key word IPA for phrases
- definition: clear 1-2 sentence English definition
- french: short French translation 1-5 words
- type: noun/verb/phrase/expression/idiom etc.

Reply ONLY with valid JSON array, no markdown:
[{{"word":"...","cloze_sentence":"...","hint":"...","phonetic":"...","definition":"...","french":"...","type":"..."}}]"""}]
    )
    raw = re.sub(r"^```json|^```|```$","",msg.content[0].text.strip(),flags=re.MULTILINE).strip()
    return json.loads(raw)


# ── Audio ─────────────────────────────────────────────────────────────────────
def get_audio(word):
    try:
        key = word.split()[0].lower()
        r = requests.get(f"https://api.dictionaryapi.dev/api/v2/entries/en/{key}", timeout=5)
        if r.ok:
            for ph in r.json()[0].get("phonetics",[]):
                if ph.get("audio"):
                    u = ph["audio"]
                    return u if u.startswith("http") else "https:"+u
    except: pass
    return None


# ── AnkiConnect ───────────────────────────────────────────────────────────────
def anki(action, **params):
    r = requests.post(ANKI_URL, json={"action":action,"version":6,"params":params}, timeout=10)
    r.raise_for_status()
    res = r.json()
    if res.get("error"): raise RuntimeError(res["error"])
    return res["result"]

def ensure_model():
    if MODEL_NAME not in anki("modelNames"):
        anki("createModel",
            modelName=MODEL_NAME,
            inOrderFields=["Word","Phonetic","Type","ClozeSentence","Hint","Definition","French","Book"],
            css=CARD_CSS,
            cardTemplates=[{"Name":"KoReader Cloze","Front":FRONT,"Back":BACK}]
        )

def add_note(card, deck, audio_url=None):
    text = card.get("cloze_sentence","")
    blank = '<span class="blank">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>'
    if "___" in text:
        cloze = re.sub(r"___+", blank, text)
        filled = re.sub(r"___+", f"<b>{card['word']}</b>", text)
    else:
        pat = re.compile(re.escape(card["word"]), re.IGNORECASE)
        cloze  = pat.sub(blank, text, count=1)
        filled = pat.sub(f"<b>{card['word']}</b>", text, count=1)

    note = {
        "deckName": deck, "modelName": MODEL_NAME,
        "fields": {
            "Word": card.get("word",""), "Phonetic": card.get("phonetic",""),
            "Type": card.get("type",""), "ClozeSentence": cloze,
            "Hint": card.get("hint",""), "Definition": card.get("definition",""),
            "French": card.get("french",""), "Book": card.get("book",""),
        },
        "options": {"allowDuplicate":False,"duplicateScope":"deck"},
        "tags": [re.sub(r"\s+","_", card.get("book","KoReader"))],
    }
    if audio_url:
        note["audio"] = [{"url":audio_url,"filename":"kr_"+re.sub(r"\s+","_",card["word"].lower())+".mp3","fields":["Word"]}]
    anki("addNote", note=note)


# ── GUI ───────────────────────────────────────────────────────────────────────
ctk.set_appearance_mode("dark")
ctk.set_default_color_theme("dark-blue")

class App(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("KoReader → Anki")
        self.geometry("620x720")
        self.resizable(False, False)
        self.configure(fg_color=BG_DARK)

        self.words      = []
        self.file_path  = None
        self.running    = False

        cfg = load_config()
        self.api_key_var = ctk.StringVar(value=cfg.get("settings","api_key",fallback=""))
        self.deck_var    = ctk.StringVar(value=cfg.get("settings","deck",fallback="KoReader Vocab"))

        self._build_ui()

    def _build_ui(self):
        # ── Header ──
        hdr = ctk.CTkFrame(self, fg_color=BG_MID, corner_radius=0, height=64)
        hdr.pack(fill="x")
        hdr.pack_propagate(False)

        ctk.CTkLabel(hdr, text="KoReader → Anki",
            font=ctk.CTkFont("Georgia", 20, "bold"),
            text_color=ACCENT).pack(side="left", padx=24, pady=16)
        ctk.CTkLabel(hdr, text=f"v{VERSION}",
            font=ctk.CTkFont(size=11), text_color=MUTED).pack(side="left")

        # ── Body ──
        body = ctk.CTkScrollableFrame(self, fg_color=BG_DARK, scrollbar_button_color=BG_CARD)
        body.pack(fill="both", expand=True, padx=0, pady=0)

        pad = {"padx":24, "pady":(12,0)}

        # ── Drop zone ──
        self.drop_frame = ctk.CTkFrame(body, fg_color=BG_CARD, corner_radius=12,
            border_width=1, border_color="#2a2d35", height=140)
        self.drop_frame.pack(fill="x", **pad)
        self.drop_frame.pack_propagate(False)

        self.drop_icon  = ctk.CTkLabel(self.drop_frame, text="📄",
            font=ctk.CTkFont(size=32))
        self.drop_icon.pack(pady=(22,4))

        self.drop_label = ctk.CTkLabel(self.drop_frame,
            text="Glisse ton fichier ici  ou  clique pour parcourir",
            font=ctk.CTkFont(size=13), text_color=MUTED)
        self.drop_label.pack()

        ctk.CTkLabel(self.drop_frame,
            text=".lua · .sqlite · .csv acceptés",
            font=ctk.CTkFont(size=11), text_color="#3a3e48").pack(pady=(2,0))

        self.drop_frame.bind("<Button-1>", lambda e: self._pick_file())
        for w in self.drop_frame.winfo_children():
            w.bind("<Button-1>", lambda e: self._pick_file())

        # ── File info (caché au départ) ──
        self.file_frame = ctk.CTkFrame(body, fg_color=BG_CARD, corner_radius=12,
            border_width=1, border_color="#2a2d35", height=64)
        self.file_frame.pack_propagate(False)

        left = ctk.CTkFrame(self.file_frame, fg_color="transparent")
        left.pack(side="left", fill="both", expand=True, padx=14, pady=10)
        self.file_name_lbl = ctk.CTkLabel(left, text="", font=ctk.CTkFont(size=13, weight="bold"),
            text_color=ACCENT, anchor="w")
        self.file_name_lbl.pack(fill="x")
        self.file_info_lbl = ctk.CTkLabel(left, text="", font=ctk.CTkFont(size=11),
            text_color=MUTED, anchor="w")
        self.file_info_lbl.pack(fill="x")

        ctk.CTkButton(self.file_frame, text="✕", width=32, height=32,
            fg_color="transparent", hover_color=BG_DARK,
            text_color=DANGER, font=ctk.CTkFont(size=14),
            command=self._reset_file).pack(side="right", padx=10)

        # ── Settings ──
        sep1 = ctk.CTkFrame(body, fg_color=BG_CARD, corner_radius=12,
            border_width=1, border_color="#2a2d35")
        sep1.pack(fill="x", **pad)

        ctk.CTkLabel(sep1, text="Configuration",
            font=ctk.CTkFont(size=11, weight="bold"),
            text_color=MUTED).pack(anchor="w", padx=16, pady=(12,6))

        # API Key
        row1 = ctk.CTkFrame(sep1, fg_color="transparent")
        row1.pack(fill="x", padx=16, pady=(0,4))
        ctk.CTkLabel(row1, text="Clé API Anthropic",
            font=ctk.CTkFont(size=12), text_color=MUTED, width=160, anchor="w").pack(side="left")
        ctk.CTkEntry(row1, textvariable=self.api_key_var, show="•",
            placeholder_text="sk-ant-...",
            fg_color=BG_DARK, border_color="#2a2d35",
            font=ctk.CTkFont("Courier", 12)).pack(side="left", fill="x", expand=True)

        # Deck
        row2 = ctk.CTkFrame(sep1, fg_color="transparent")
        row2.pack(fill="x", padx=16, pady=(0,12))
        ctk.CTkLabel(row2, text="Nom du deck Anki",
            font=ctk.CTkFont(size=12), text_color=MUTED, width=160, anchor="w").pack(side="left")
        ctk.CTkEntry(row2, textvariable=self.deck_var,
            fg_color=BG_DARK, border_color="#2a2d35").pack(side="left", fill="x", expand=True)

        # AnkiConnect reminder
        ctk.CTkLabel(sep1,
            text="⚠  Anki doit être ouvert · Add-on AnkiConnect requis (code : 2055492159)",
            font=ctk.CTkFont(size=11), text_color="#c8a820").pack(anchor="w", padx=16, pady=(0,12))

        # ── Generate button ──
        self.btn = ctk.CTkButton(body,
            text="✦  Générer les cartes",
            font=ctk.CTkFont("Georgia", 15, "bold"),
            fg_color=ACCENT, hover_color="#a8d040",
            text_color=BG_DARK, height=52, corner_radius=12,
            command=self._start)
        self.btn.pack(fill="x", padx=24, pady=(18,0))

        # ── Progress ──
        self.prog_frame = ctk.CTkFrame(body, fg_color=BG_CARD, corner_radius=12,
            border_width=1, border_color="#2a2d35")

        self.prog_bar = ctk.CTkProgressBar(self.prog_frame,
            fg_color=BG_DARK, progress_color=ACCENT, height=4)
        self.prog_bar.pack(fill="x", padx=16, pady=(16,6))
        self.prog_bar.set(0)

        self.prog_label = ctk.CTkLabel(self.prog_frame, text="",
            font=ctk.CTkFont("Courier", 11), text_color=MUTED, anchor="w")
        self.prog_label.pack(fill="x", padx=16)

        self.log_box = ctk.CTkTextbox(self.prog_frame,
            fg_color=BG_DARK, text_color="#a0a4ae",
            font=ctk.CTkFont("Courier", 11),
            height=180, border_width=0, wrap="word")
        self.log_box.pack(fill="x", padx=16, pady=(4,16))

        # ── Stats ──
        self.stats_frame = ctk.CTkFrame(body, fg_color="transparent")

        for attr, label, color in [
            ("stat_added","Cartes ajoutées", SUCCESS),
            ("stat_audio","Avec audio",      INFO),
            ("stat_fail", "Échouées",        DANGER),
        ]:
            card = ctk.CTkFrame(self.stats_frame, fg_color=BG_CARD,
                corner_radius=10, border_width=1, border_color="#2a2d35")
            card.pack(side="left", fill="both", expand=True, padx=4)
            lbl = ctk.CTkLabel(card, text="0",
                font=ctk.CTkFont("Georgia", 32, "bold"), text_color=color)
            lbl.pack(pady=(14,2))
            ctk.CTkLabel(card, text=label,
                font=ctk.CTkFont(size=11), text_color=MUTED).pack(pady=(0,14))
            setattr(self, attr, lbl)

        # ── Footer spacer ──
        ctk.CTkFrame(body, fg_color="transparent", height=24).pack()

    # ── File handling ─────────────────────────────────────────────────────────
    def _pick_file(self):
        path = filedialog.askopenfilename(
            title="Sélectionne ton fichier KoReader",
            filetypes=[("KoReader files","*.lua *.sqlite *.db *.csv"),("All files","*.*")]
        )
        if path: self._load_file(path)

    def _load_file(self, path):
        self.log("info", f"Lecture de {Path(path).name}...")
        words = load_words(path)
        if not words:
            messagebox.showerror("Erreur", "Aucun mot trouvé dans ce fichier.")
            return
        self.words     = words
        self.file_path = path

        self.drop_frame.pack_forget()
        self.file_name_lbl.configure(text=Path(path).name)
        self.file_info_lbl.configure(text=f"{len(words)} expressions détectées")
        self.file_frame.pack(fill="x", padx=24, pady=(12,0))
        self.log("ok", f"✓  {len(words)} expressions chargées")

    def _reset_file(self):
        self.words = []; self.file_path = None
        self.file_frame.pack_forget()
        self.drop_frame.pack(fill="x", padx=24, pady=(12,0))
        self.log_box.delete("1.0","end")
        self.prog_frame.pack_forget()
        self.stats_frame.pack_forget()
        self.prog_bar.set(0)

    # ── Generation ────────────────────────────────────────────────────────────
    def _start(self):
        if self.running: return
        if not self.words:
            messagebox.showwarning("Fichier manquant", "Importe un fichier d'abord.")
            return
        api_key = self.api_key_var.get().strip()
        if not api_key or not api_key.startswith("sk-"):
            messagebox.showwarning("Clé API manquante", "Entre ta clé API Anthropic.")
            return
        save_config(api_key, self.deck_var.get())

        self.prog_frame.pack(fill="x", padx=24, pady=(14,0))
        self.stats_frame.pack(fill="x", padx=24, pady=(10,0))
        self.btn.configure(state="disabled", text="Génération en cours…")
        self.running = True

        threading.Thread(target=self._run, daemon=True).start()

    def _run(self):
        deck    = self.deck_var.get().strip() or "KoReader Vocab"
        api_key = self.api_key_var.get().strip()
        client  = anthropic.Anthropic(api_key=api_key)
        words   = self.words
        stats   = {"added":0, "audio":0, "failed":0}

        # Anki setup
        try:
            anki("createDeck", deck=deck)
            ensure_model()
            self.log("ok", f"✓  Deck '{deck}' prêt")
        except Exception as e:
            self.log("err", f"✗  AnkiConnect : {e}")
            self._finish(stats)
            return

        batches = [words[i:i+BATCH_SIZE] for i in range(0,len(words),BATCH_SIZE)]
        total   = len(words)
        done    = 0

        for i, batch in enumerate(batches):
            self._set_prog(done/total, f"Lot {i+1}/{len(batches)} — Claude génère les cartes…")
            self.log("info", f"→ Lot {i+1}/{len(batches)}")

            try:
                cards = generate_cards(batch, client)
                for j, card in enumerate(cards):
                    card["book"] = batch[j]["book"] if j < len(batch) else ""
            except Exception as e:
                self.log("err", f"  ✗ Erreur Claude : {str(e)[:60]}")
                stats["failed"] += len(batch)
                done += len(batch)
                continue

            for card in cards:
                w = card.get("word","")[:40]
                audio = get_audio(card.get("word",""))
                try:
                    add_note(card, deck, audio)
                    stats["added"] += 1
                    if audio: stats["audio"] += 1
                    self.log("ok", f"  ✓  {w}" + (" 🔊" if audio else ""))
                except RuntimeError as e:
                    err = str(e)
                    if "duplicate" in err.lower():
                        self.log("warn", f"  ⚠  {w} — déjà présent")
                    else:
                        stats["failed"] += 1
                        self.log("err", f"  ✗  {w} — {err[:50]}")
                done += 1
                self._set_prog(done/total, f"{done}/{total} cartes traitées")
                self._set_stats(stats)
                time.sleep(0.05)

            time.sleep(0.3)

        self._set_prog(1.0, "✓  Terminé !")
        self._set_stats(stats)
        self._finish(stats)

    def _finish(self, stats):
        self.running = False
        self.after(0, lambda: self.btn.configure(state="normal", text="✦  Générer les cartes"))
        self.log("ok", f"\n━━━  {stats['added']} cartes ajoutées · {stats['audio']} avec audio · {stats['failed']} échouées  ━━━")

    # ── Helpers ───────────────────────────────────────────────────────────────
    def log(self, kind, msg):
        colors = {"ok": SUCCESS, "err": DANGER, "warn": "#fbbf24", "info": MUTED}
        color  = colors.get(kind, MUTED)
        def _do():
            self.log_box.configure(state="normal")
            self.log_box.insert("end", msg + "\n")
            self.log_box.configure(state="disabled")
            self.log_box.see("end")
        self.after(0, _do)

    def _set_prog(self, val, txt):
        self.after(0, lambda: self.prog_bar.set(val))
        self.after(0, lambda: self.prog_label.configure(text=txt))

    def _set_stats(self, s):
        self.after(0, lambda: self.stat_added.configure(text=str(s["added"])))
        self.after(0, lambda: self.stat_audio.configure(text=str(s["audio"])))
        self.after(0, lambda: self.stat_fail.configure(text=str(s["failed"])))


if __name__ == "__main__":
    app = App()
    app.mainloop()
